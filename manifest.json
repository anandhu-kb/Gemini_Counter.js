{
  "manifest_version": 3,
  "name": "Gemini Token Counter",
  "version": "1.0",
  "description": "Token counter and progress bar for Gemini",
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
